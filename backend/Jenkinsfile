pipeline {
    agent any

    tools {
        maven 'maven_3'
    }

    stages {

        stage('Step 1: Pull Code') {
            steps {
                checkout scm
            }
        }

        stage('Step 2: Maven Build All Microservices') {
            steps {
                dir('backend') {
                    sh 'mvn clean install -Dmaven.test.skip=true'
                }
            }
        }

        stage('Step 3: Stop Old Containers') {
            steps {
                catchError(buildResult: 'SUCCESS', stageResult: 'UNSTABLE') {
                    dir('backend') {
                        sh 'docker-compose down --remove-orphans || true'
                    }
                }
                sh 'docker ps --format "{{.ID}} {{.Ports}}" | grep ":9001->" | awk \'{print $1}\' | xargs -r docker rm -f || true'
                sh 'docker ps --format "{{.ID}} {{.Ports}}" | grep ":4200->" | awk \'{print $1}\' | xargs -r docker rm -f || true'
                sh 'docker ps -aq --filter "name=backend-" | xargs -r docker rm -f || true'
            }
        }

        stage('Step 4: Docker Compose Build') {
            steps {
                catchError(buildResult: 'SUCCESS', stageResult: 'UNSTABLE') {
                    dir('backend') {
                        sh 'docker-compose build'
                    }
                }
            }
        }

        stage('Step 5: Deploy & Run All (Docker)') {
            steps {
                catchError(buildResult: 'SUCCESS', stageResult: 'UNSTABLE') {
                    dir('backend') {
                        sh 'docker-compose up -d --force-recreate'
                    }
                }
            }
        }

        stage('Step 6: SonarQube Analysis') {
            steps {
                catchError(buildResult: 'SUCCESS', stageResult: 'UNSTABLE') {
                    sh '''
                        echo "Waiting for SonarQube to be ready..."
                        for i in $(seq 1 24); do
                            STATUS=$(curl -s http://host.docker.internal:9001/api/system/status | grep -o '"status":"[A-Z]*"' | head -1)
                            echo "Attempt $i: $STATUS"
                            if echo "$STATUS" | grep -q "UP"; then
                                echo "SonarQube is UP"
                                break
                            fi
                            sleep 10
                        done
                    '''
                    dir('backend') {
                        sh 'mvn sonar:sonar -Dsonar.host.url=http://host.docker.internal:9001 -Dsonar.login=admin -Dsonar.password=admin123 -Dmaven.test.skip=true'
                    }
                }
            }
        }

        stage('Step 7: Deploy to K3s / Kubernetes') {
            steps {
                catchError(buildResult: 'SUCCESS', stageResult: 'UNSTABLE') {
                    sh 'kubectl apply -f k8s/namespace.yaml || true'
                    sh 'kubectl apply -f k8s/infrastructure/ || true'
                    sh 'kubectl apply -f k8s/microservices/ || true'
                    sh 'kubectl apply -f k8s/ai/ || true'
                    sh 'kubectl apply -f k8s/frontend/ || true'
                    sh 'kubectl apply -f k8s/monitoring/ || true'
                }
            }
        }

        stage('Step 8: Health Check') {
            steps {
                sleep(time: 20, unit: 'SECONDS')
                sh 'curl -f http://localhost:8761 || echo "Eureka not ready yet"'
                sh 'curl -f http://localhost:4200 || echo "Frontend not ready yet"'
                sh 'curl -f http://localhost:9001 || echo "SonarQube not ready yet"'
            }
        }

    }

    post {
        success {
            echo '✅ NexLance complet : Frontend→4200 | Gateway→8080 | Eureka→8761 | SonarQube→9001 | Grafana→3000 | Prometheus→9093'
        }
        failure {
            echo '❌ Build échoué. Vérifier le Console Output Jenkins.'
        }
        always {
            echo '--- Fin du pipeline NexLance ---'
        }
    }
}
