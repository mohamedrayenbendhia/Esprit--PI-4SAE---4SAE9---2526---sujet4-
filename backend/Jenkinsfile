 pipeline {
    agent any

    tools {
        maven 'maven_3'
    }

    environment {
        JAVA_HOME = '/opt/java/openjdk'
        MVN = '/opt/apache-maven-3.9.6/bin/mvn'
        SONAR_HOST = 'http://172.17.0.1:9001'
        K3S_IMAGES = 'img-eureka img-config-server img-gateway img-user img-complaint img-contrat img-evaluation img-joboffer img-certification img-portfolio img-competence img-notification img-organization img-projects img-recommendation img-nexlance-front img-prometheus'
    }

    stages {

        stage('Step 1: Pull Code') {
            steps {
                checkout scm
            }
        }

        stage('Step 2: Maven Build All Microservices') {
            steps {
                dir('backend') {
                    sh '${MVN} clean install -Dmaven.test.skip=true'
                }
            }
        }

        stage('Step 3: Stop Old Containers') {
            steps {
                catchError(buildResult: 'SUCCESS', stageResult: 'UNSTABLE') {
                    dir('backend') {
                        sh 'docker-compose down --remove-orphans || true'
                    }
                }
                sh 'docker ps --format "{{.ID}} {{.Ports}}" | grep ":9001->" | awk \'{print $1}\' | xargs -r docker rm -f || true'
                sh 'docker ps --format "{{.ID}} {{.Ports}}" | grep ":4200->" | awk \'{print $1}\' | xargs -r docker rm -f || true'
                sh 'docker ps -aq --filter "name=backend-" | xargs -r docker rm -f || true'
            }
        }

        stage('Step 4: Docker Compose Build') {
            steps {
                catchError(buildResult: 'SUCCESS', stageResult: 'UNSTABLE') {
                    dir('backend') {
                        sh 'docker-compose build'
                    }
                }
            }
        }

        stage('Step 5: Export Images to K3s Containerd') {
            steps {
                catchError(buildResult: 'SUCCESS', stageResult: 'UNSTABLE') {
                    sh '''
                        echo "Importing Docker images into K3s containerd..."
                        mkdir -p /tmp/k3s-images
                        for img in $K3S_IMAGES; do
                            if docker image inspect "$img" > /dev/null 2>&1; then
                                echo "  -> Saving $img to tar..."
                                docker save "$img" -o /tmp/k3s-images/${img}.tar
                                echo "  -> Importing $img into K3s..."
                                sudo k3s ctr images import /tmp/k3s-images/${img}.tar
                                rm -f /tmp/k3s-images/${img}.tar
                            else
                                echo "  !! Image $img not found, skipping"
                            fi
                        done
                        rm -rf /tmp/k3s-images 2>/dev/null || true
                        echo "Image import complete."
                        sudo k3s ctr images ls | grep "img-"
                    '''
                }
            }
        }

        stage('Step 6: Deploy & Run All (Docker)') {
            steps {
                catchError(buildResult: 'SUCCESS', stageResult: 'UNSTABLE') {
                    dir('backend') {
                        sh 'docker-compose up -d --force-recreate'
                    }
                }
            }
        }

        stage('Step 7: SonarQube Analysis') {
            steps {
                catchError(buildResult: 'SUCCESS', stageResult: 'UNSTABLE') {
                    sh '''
                        echo "Waiting for SonarQube to be ready (max 5 min)..."
                        i=0
                        while [ $i -lt 30 ]; do
                            i=$((i+1))
                            STATUS=$(curl -s ${SONAR_HOST}/api/system/status 2>/dev/null)
                            echo "Attempt $i: $STATUS"
                            if echo "$STATUS" | grep -q '"status":"UP"'; then
                                echo "SonarQube is UP"
                                break
                            fi
                            sleep 10
                        done
                    '''
                    dir('backend') {
                        sh '${MVN} sonar:sonar -Dsonar.host.url=${SONAR_HOST} -Dmaven.test.skip=true'
                    }
                }
            }
        }

        stage('Step 8: Deploy to K3s / Kubernetes') {
            steps {
                catchError(buildResult: 'SUCCESS', stageResult: 'UNSTABLE') {
                    sh 'kubectl apply -f k8s/namespace.yaml'
                    sh 'kubectl apply -f k8s/infrastructure/'
                    sh 'kubectl apply -f k8s/microservices/'
                    sh 'kubectl apply -f k8s/ai/'
                    sh 'kubectl apply -f k8s/frontend/'
                    sh 'kubectl apply -f k8s/monitoring/'
                    sh '''
                        echo "Waiting for pods to be ready..."
                        kubectl rollout status deployment/eureka-server -n nexlance --timeout=120s || true
                        kubectl rollout status deployment/api-gateway    -n nexlance --timeout=120s || true
                        kubectl rollout status deployment/frontend        -n nexlance --timeout=120s || true
                    '''
                }
            }
        }

        stage('Step 9: Health Check') {
            steps {
                sh 'kubectl get pods -n nexlance'
                sh 'kubectl get svc  -n nexlance'
                sh 'curl -f http://localhost:8761 || echo "Eureka (Docker) not ready yet"'
                sh 'curl -f http://localhost:4200 || echo "Frontend (Docker) not ready yet"'
                sh 'curl -f http://localhost:9001 || echo "SonarQube not ready yet"'
                sh 'curl -f http://localhost:30761 || echo "Eureka (K3s NodePort) not ready yet"'
                sh 'curl -f http://localhost:30420 || echo "Frontend (K3s NodePort) not ready yet"'
            }
        }
    }

    post {
        success {
            echo ' NexLance pipeline OK | Docker→4200/8080/8761 | K3s→30420/30080/30761 | SonarQube→9001 | Grafana→3000'
        }
        failure {
            echo ' Build échoué. Vérifier le Console Output Jenkins.'
        }
        always {
            echo '--- Fin du pipeline NexLance ---'
        }
    }
}
